{
  "version": 1,
  "primitives": {
    "sys.sh": {
      "description": "System observation primitives",
      "arg0": "host",
      "arg1": "command",
      "allowed_commands": [
        "summary",
        "disk",
        "memory",
        "load",
        "journal",
        "dmesg",
        "users"
      ],
      "risk_by_command": {
        "*": "low"
      },
      "unattended": {
        "L1": true,
        "L2": true,
        "L3": true
      }
    },
    "facts.sh": {
      "description": "Host facts gathering",
      "arg0": "host",
      "allowed_args": [
        "*"
      ],
      "risk": "low",
      "unattended": {
        "L1": true,
        "L2": true,
        "L3": true
      }
    },
    "patrol.sh": {
      "description": "Scheduled observation patrol",
      "arg0": "host",
      "arg1": "mode (summary|full|quick)",
      "allowed_args": [
        "*"
      ],
      "risk": "low",
      "unattended": {
        "L1": true,
        "L2": true,
        "L3": true
      }
    },
    "file.sh": {
      "description": "File operations",
      "arg0": "host",
      "arg1": "command",
      "allowed_commands": [
        "exists",
        "stat",
        "list",
        "head",
        "tail",
        "grep",
        "checksum",
        "backup",
        "mkdir",
        "remove"
      ],
      "risk_by_command": {
        "exists": "low",
        "stat": "low",
        "list": "low",
        "head": "low",
        "tail": "low",
        "grep": "low",
        "checksum": "low",
        "backup": "low",
        "mkdir": "medium",
        "remove": "high"
      },
      "unattended": {
        "L1": [
          "exists",
          "stat",
          "list",
          "head",
          "tail",
          "grep",
          "checksum"
        ],
        "L2": [
          "backup"
        ],
        "L3": [
          "mkdir"
        ],
        "L4": [
          "remove"
        ]
      }
    },
    "proc.sh": {
      "description": "Process operations",
      "arg0": "host",
      "arg1": "command",
      "allowed_commands": [
        "top",
        "mem",
        "find",
        "tree",
        "kill"
      ],
      "risk_by_command": {
        "top": "low",
        "mem": "low",
        "find": "low",
        "tree": "low",
        "kill": "high"
      },
      "unattended": {
        "L1": [
          "top",
          "mem",
          "find",
          "tree"
        ],
        "L3": [],
        "L4": [
          "kill"
        ]
      }
    },
    "net.sh": {
      "description": "Network observation",
      "arg0": "host",
      "arg1": "command",
      "allowed_commands": [
        "ports",
        "listen",
        "curl",
        "dns",
        "route",
        "addr"
      ],
      "risk_by_command": {
        "*": "low"
      },
      "unattended": {
        "L1": [
          "ports",
          "listen",
          "dns",
          "route",
          "addr"
        ],
        "L2": [
          "curl"
        ]
      }
    },
    "pkg.sh": {
      "description": "Package management",
      "arg0": "host",
      "arg1": "command",
      "allowed_commands": [
        "detect",
        "search",
        "installed",
        "update-cache",
        "install",
        "remove"
      ],
      "risk_by_command": {
        "detect": "low",
        "search": "low",
        "installed": "low",
        "update-cache": "medium",
        "install": "high",
        "remove": "high"
      },
      "unattended": {
        "L1": [
          "detect",
          "installed",
          "search"
        ],
        "L3": [
          "update-cache"
        ],
        "L4": [
          "install",
          "remove"
        ]
      }
    },
    "service.sh": {
      "description": "Service management",
      "arg0": "host",
      "arg1": "command",
      "allowed_commands": [
        "status",
        "logs",
        "restart",
        "reload",
        "stop",
        "disable"
      ],
      "risk_by_command": {
        "status": "low",
        "logs": "low",
        "restart": "medium",
        "reload": "medium",
        "stop": "high",
        "disable": "high"
      },
      "unattended": {
        "L1": [
          "status",
          "logs"
        ],
        "L3": [
          "restart",
          "reload"
        ],
        "L4": [
          "stop",
          "disable"
        ]
      }
    },
    "lock.sh": {
      "description": "Write coordination locks",
      "arg0": "host",
      "arg1": "command",
      "allowed_commands": [
        "status",
        "acquire",
        "release"
      ],
      "risk_by_command": {
        "status": "low",
        "acquire": "low",
        "release": "low"
      },
      "unattended": {
        "L1": [
          "status"
        ],
        "L2": [
          "acquire",
          "release"
        ]
      }
    },
    "connect.sh": {
      "description": "SSH ControlMaster connect",
      "arg0": "host",
      "risk": "low",
      "unattended": {
        "L2": true
      }
    },
    "disconnect.sh": {
      "description": "SSH ControlMaster disconnect",
      "arg0": "host",
      "risk": "low",
      "unattended": {
        "L2": true
      }
    },
    "exec.sh": {
      "description": "Raw command execution (use primitives first)",
      "arg0": "host",
      "risk_by_args": {
        "*": "high"
      },
      "unattended": {
        "L1": false,
        "L2": false,
        "L3": false,
        "L4": true
      },
      "note": "L4 requires --allow-raw-exec or --confirm; gate enforces this separately."
    },
    "scp_transfer.sh": {
      "description": "File transfer",
      "arg0": "host",
      "arg1": "direction (upload|download)",
      "risk": "medium",
      "unattended": {
        "L3": true,
        "L4": true
      }
    },
    "composite.sh": {
      "description": "Read-only composite observation primitives",
      "arg0": "host",
      "arg1": "action",
      "allowed_commands": [
        "healthcheck",
        "disk",
        "memory",
        "services",
        "network",
        "quick",
        "journal",
        "all"
      ],
      "risk_by_command": {
        "*": "low"
      },
      "unattended": {
        "L1": [
          "healthcheck",
          "disk",
          "memory",
          "services",
          "network",
          "quick",
          "journal",
          "all"
        ],
        "L2": true,
        "L3": true
      }
    }
  }
}