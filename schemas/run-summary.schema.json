{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kakahu2015/ssh-skill/schemas/run-summary.schema.json",
  "title": "SSH Skill Run Summary",
  "description": "Schema for run_*.json summary files generated by runner.sh and batch operations",
  "type": "object",
  "required": ["success", "run_id", "timestamp"],
  "properties": {
    "success": {
      "type": "boolean",
      "description": "Whether the overall run succeeded"
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "mode": {
      "type": "string",
      "enum": ["batch", "sequential", "gate"],
      "description": "Execution mode"
    },
    "gate_result": {
      "type": "object",
      "description": "Gate validation result if gate was used",
      "$ref": "gate-result.schema.json"
    },
    "decision_file": {
      "type": "string",
      "description": "Path to the decision record that initiated this run"
    },
    "target": {
      "type": "object",
      "description": "Target specification",
      "properties": {
        "hosts": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Target host names"
        },
        "tags": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Target tags"
        },
        "environment": {
          "type": "string",
          "description": "Target environment"
        }
      }
    },
    "action": {
      "type": "object",
      "description": "Action executed",
      "properties": {
        "primitive": {"type": "string"},
        "args": {"type": "array", "items": {"type": "string"}},
        "command": {"type": "string", "description": "Full command string"}
      }
    },
    "host_results": {
      "type": "object",
      "description": "Per-host result summary",
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "ok": {"type": "integer", "minimum": 0},
        "failed": {"type": "integer", "minimum": 0},
        "skipped": {"type": "integer", "minimum": 0}
      }
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Total execution duration in milliseconds"
    },
    "audit_files": {
      "type": "object",
      "description": "Paths to generated audit files",
      "properties": {
        "decision": {"type": "string"},
        "events": {"type": "array", "items": {"type": "string"}},
        "escalation": {"type": "string"}
      }
    },
    "errors": {
      "type": "array",
      "description": "Error messages for failed operations",
      "items": {
        "type": "object",
        "properties": {
          "host": {"type": "string"},
          "error": {"type": "string"},
          "exit_code": {"type": "integer"}
        }
      }
    }
  }
}
