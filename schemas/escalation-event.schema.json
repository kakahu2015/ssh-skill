{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kakahu2015/ssh-skill/schemas/escalation-event.schema.json",
  "title": "SSH Skill Escalation Event",
  "description": "Schema for escalation events generated by agent_gate when an action is blocked",
  "type": "object",
  "required": ["time", "run_id", "action", "reason", "error", "message", "success"],
  "properties": {
    "time": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "action": {
      "type": "string",
      "description": "Action type, always 'escalation'"
    },
    "reason": {
      "type": "string",
      "description": "Escalation category: 'gate_block'"
    },
    "error": {
      "type": "string",
      "description": "Gate error code that triggered the escalation"
    },
    "message": {
      "type": "string",
      "description": "Human-readable error message"
    },
    "success": {
      "type": "boolean",
      "description": "Always false for escalation events"
    },
    "exit_code": {
      "type": "integer",
      "description": "Always 0 for escalation events"
    },
    "duration_ms": {
      "type": "integer",
      "description": "Always 0 for escalation events"
    },
    "command": {
      "type": "string",
      "description": "Empty for escalation events"
    },
    "audit_files": {
      "type": "object",
      "description": "Paths to related audit files",
      "properties": {
        "decision": {"type": "string"},
        "events": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
