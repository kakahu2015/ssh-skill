{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kakahu2015/ssh-skill/schemas/audit-event.schema.json",
  "title": "SSH Skill Audit Event",
  "description": "Schema for runtime audit events generated by agent_gate and primitives",
  "type": "object",
  "required": ["time", "run_id", "host", "action", "success", "exit_code", "duration_ms"],
  "properties": {
    "time": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "host": {
      "type": "string",
      "description": "Target host name (may be redacted)"
    },
    "action": {
      "type": "string",
      "pattern": "^(execute|verify|rollback):",
      "description": "Action type and primitive name"
    },
    "success": {
      "type": "boolean",
      "description": "Whether the action succeeded"
    },
    "exit_code": {
      "type": "integer",
      "description": "Process exit code"
    },
    "duration_ms": {
      "type": "integer",
      "description": "Execution duration in milliseconds"
    },
    "command": {
      "type": "string",
      "description": "Redacted command text"
    },
    "decision_snapshot": {
      "type": "object",
      "description": "Snapshot of the decision record at execution time (optional, enhanced audit)",
      "properties": {
        "intent": {"type": "string"},
        "autonomy_level": {"type": "string", "pattern": "^L[0-5]$"},
        "risk": {"type": "string", "enum": ["low", "medium", "high", "forbidden"]},
        "environment": {"type": "string"},
        "host_count": {"type": "integer", "minimum": 0},
        "observations_snapshot": {"type": "array", "items": {"type": "string"}},
        "stop_condition": {"type": "string"}
      }
    },
    "gate_checks": {
      "type": "object",
      "description": "Gate validation results (optional, enhanced audit)",
      "properties": {
        "level_check": {"type": "string", "enum": ["pass", "block", "skip"]},
        "risk_check": {"type": "string", "enum": ["pass", "block", "skip"]},
        "confirmation_check": {"type": "string", "enum": ["pass", "block", "skip"]},
        "host_count_check": {"type": "string", "enum": ["pass", "block", "skip"]},
        "primitive_check": {"type": "string", "enum": ["pass", "block", "skip"]},
        "semantic_check": {"type": "string", "enum": ["pass", "block", "skip"]}
      }
    },
    "verification_results": {
      "type": "array",
      "description": "Results of verification actions (optional, enhanced audit)",
      "items": {
        "type": "object",
        "properties": {
          "action": {"type": "string"},
          "success": {"type": "boolean"},
          "exit_code": {"type": "integer"}
        }
      }
    },
    "rollback_results": {
      "type": "array",
      "description": "Results of rollback actions (optional, enhanced audit)",
      "items": {
        "type": "object",
        "properties": {
          "action": {"type": "string"},
          "success": {"type": "boolean"},
          "exit_code": {"type": "integer"}
        }
      }
    },
    "escalation": {
      "type": "object",
      "description": "Escalation event if gate blocked the action (optional, enhanced audit)",
      "properties": {
        "triggered": {"type": "boolean"},
        "reason": {"type": "string"},
        "timestamp": {"type": "string", "format": "date-time"},
        "target": {"type": "string", "description": "Escalation target (webhook URL or channel)"}
      }
    }
  }
}
