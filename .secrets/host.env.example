# .secrets/<host>.env
# Copy this file to .secrets/<host>.env and fill in real connection values.
# This example is safe to commit; real .env files are ignored by .gitignore.

# Required for all hosts. Use a real IP or domain in your local copy only.
HOST=203.0.113.10

# Required for key auth. Use the real private-key path in your local copy only.
KEY_PATH=/path/to/private/key

# Required only for password auth. Keep it local and never commit it.
# SSH_PASSWORD=your_password_here
